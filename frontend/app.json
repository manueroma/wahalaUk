{
  "expo": {
    "name": "WAHALA UK",
    "slug": "wahala-uk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/wahala-logo.png",
    "scheme": "wahalauk",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wahalauk.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Select photos for your profile",
        "NSCameraUsageDescription": "Take photos and videos to share",
        "NSMicrophoneUsageDescription": "Record audio for video messages",
        "NSLocationWhenInUseUsageDescription": "Show nearby matches"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/wahala-logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.wahalauk.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/wahala-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/wahala-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Select photos for your dating profile",
          "cameraPermission": "Take photos and videos to share with matches"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Record audio for video snaps"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Show you potential matches nearby"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
